    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const raw = $json.choices[0].message.content;\n\nconst cleaned = raw\n  .replace(/```json\\s*/i, '')\n  .replace(/```/g, '')\n  .trim();\n\nconst enrichment = JSON.parse(cleaned);\nreturn {\n  issue_summary: enrichment.issue_summary,\n  identifiers: enrichment.identifiers,\n  urgency: enrichment.urgency\n};"
      },
