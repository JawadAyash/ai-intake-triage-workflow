        "jsCode": "const raw = $json.choices[0].message.content;\n\n// Remove markdown code fences if present\nconst cleaned = raw\n  .replace(/```json\\s*/i, '')\n  .replace(/```/g, '')\n  .trim();\n\nconst classification = JSON.parse(cleaned);\n\nreturn {\n  original_message: $('Webhook').first().json.body.message,\n  source: $('Webhook').first().json.body.source,\n  category: classification.category,\n  priority: classification.priority,\n  confidence: classification.confidence\n};"
      },
