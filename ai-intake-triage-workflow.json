        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n \"model\": \"gpt-4o-mini\",\n \"temperature\": 0,\n \"messages\": [\n  {\n   \"role\": \"system\",\n   \"content\": \"You classify customer support tickets.\"\n  },\n  {\n   \"role\": \"user\",\n   \"content\": \"Classify the support request.\\n\\nReturn ONLY JSON with:\\ncategory\\npriority\\nconfidence\\n\\nAllowed categories:\\nBug Report\\nFeature Request\\nBilling Issue\\nTechnical Question\\nIncident/Outage\\n\\nUse exactly one of these categories.\\n\\nMessage:\\n{{$json.body.message}}\"\n  }\n ]\n}",
        "options": {}
