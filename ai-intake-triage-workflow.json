        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n \"model\": \"gpt-4o-mini\",\n \"temperature\": 0,\n \"messages\": [\n  {\n   \"role\": \"system\",\n   \"content\": \"You extract structured data from support messages.\"\n  },\n  {\n   \"role\": \"user\",\n   \"content\": \"Extract structured information.\\n\\nReturn ONLY JSON with:\\nissue_summary\\nidentifiers\\nurgency\\n\\nMessage:\\n{{$json.original_message}}\"\n  }\n ]\n}",
